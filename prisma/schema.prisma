generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ SUPER ADMIN (platform owner) ============

model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

// ============ SCHOOL ============

model School {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique // URL-friendly identifier
  currentTerm  String   @default("term1")
  academicYear String   @default("2025-2026")
  isActive     Boolean  @default(true)
  admins       Admin[]
  teachers     Teacher[]
  yearGroups   YearGroup[]
  classGroups  ClassGroup[]
  students     Student[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============ SCHOOL AUTH ============

model Admin {
  id           String   @id @default(cuid())
  email        String
  passwordHash String
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([email, schoolId])
}

model Teacher {
  id                 String              @id @default(cuid())
  firstName          String
  lastName           String
  email              String              @unique
  passwordHash       String
  schoolId           String
  school             School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes            ClassGroup[]
  teacherAssessments TeacherAssessment[]
  createdAt          DateTime            @default(now())
}

// ============ SCHOOL STRUCTURE ============

model YearGroup {
  id        String       @id @default(cuid())
  name      String
  sortOrder Int          @default(0)
  tier      String       @default("standard")
  schoolId  String
  school    School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes   ClassGroup[]
  students  Student[]
  createdAt DateTime     @default(now())

  @@unique([schoolId, name])
}

model ClassGroup {
  id          String    @id @default(cuid())
  name        String
  yearGroupId String
  yearGroup   YearGroup @relation(fields: [yearGroupId], references: [id], onDelete: Cascade)
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students    Student[]
  teachers    Teacher[]
  createdAt   DateTime  @default(now())

  @@unique([yearGroupId, name])
}

// ============ STUDENTS ============

model Student {
  id                 String              @id @default(cuid())
  loginCode          String              @unique
  firstName          String
  lastName           String
  displayName        String?
  yearGroup          String
  className          String?
  yearGroupId        String?
  yearGroupRef       YearGroup?          @relation(fields: [yearGroupId], references: [id])
  classGroupId       String?
  classGroupRef      ClassGroup?         @relation(fields: [classGroupId], references: [id])
  tier               String              @default("standard")
  schoolUuid         String?
  schoolId           String
  school             School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt          DateTime            @default(now())
  assessments        Assessment[]
  teacherAssessments TeacherAssessment[]
}

// ============ STUDENT QUESTIONS & ASSESSMENTS ============

model Question {
  id             String  @id @default(cuid())
  tier           String  @default("standard")
  orderIndex     Int
  prompt         String
  domain         String
  type           String
  questionFormat String
  answerOptions  String
  scoreMap       String
  weight         Float   @default(1.0)
  isValidation   Boolean @default(false)
  isTrap         Boolean @default(false)
  validationPair Int?

  @@unique([tier, orderIndex])
}

model Assessment {
  id                    String    @id @default(cuid())
  studentId             String
  student               Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tier                  String    @default("standard")
  term                  String    @default("term1")
  academicYear          String    @default("2025-2026")
  status                String    @default("in_progress")
  answers               String    @default("{}")
  totalScore            Float?
  overallLevel          String?
  knowMeScore           Float?
  manageMeScore         Float?
  understandOthersScore Float?
  workWithOthersScore   Float?
  chooseWellScore       Float?
  knowMeLevel           String?
  manageMeLevel         String?
  understandOthersLevel String?
  workWithOthersLevel   String?
  chooseWellLevel       String?
  reliabilityScore      String?
  rawResponseJson       String?
  lastQuestionNum       Int       @default(0)
  startedAt             DateTime  @default(now())
  completedAt           DateTime?

  @@unique([studentId, term, academicYear])
}

// ============ TEACHER QUESTIONS & ASSESSMENTS ============

model TeacherQuestion {
  id            String @id @default(cuid())
  orderIndex    Int    @unique
  prompt        String
  domain        String
  answerOptions String
  scoreMap      String
  weight        Float  @default(1.0)
}

model TeacherAssessment {
  id                    String    @id @default(cuid())
  teacherId             String
  teacher               Teacher   @relation(fields: [teacherId], references: [id])
  studentId             String
  student               Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term                  String
  academicYear          String    @default("2025-2026")
  status                String    @default("in_progress")
  answers               String    @default("{}")
  knowMeScore           Float?
  manageMeScore         Float?
  understandOthersScore Float?
  workWithOthersScore   Float?
  chooseWellScore       Float?
  knowMeLevel           String?
  manageMeLevel         String?
  understandOthersLevel String?
  workWithOthersLevel   String?
  chooseWellLevel       String?
  completedAt           DateTime?
  createdAt             DateTime  @default(now())

  @@unique([teacherId, studentId, term, academicYear])
}

// ============ INTERVENTIONS ============

model Intervention {
  id          String   @id @default(cuid())
  domain      String
  level       String
  tier        String   @default("standard")
  audience    String
  title       String
  description String
  sortOrder   Int      @default(0)
  isDefault   Boolean  @default(true)
  schoolId    String?  // null = system default, set = school custom
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
