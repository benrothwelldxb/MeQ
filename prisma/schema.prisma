generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============ SUPER ADMIN (platform owner) ============

model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

// ============ SCHOOL ============

model School {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique // URL-friendly identifier
  currentTerm  String   @default("term1")
  academicYear String   @default("2025-2026")
  isActive              Boolean  @default(true)
  // Reduced-question mode is set per tier so a school running the full
  // assessment for older students can still use the shorter version for
  // junior — common when juniors fatigue faster.
  reducedJunior         Boolean  @default(false)
  reducedStandard       Boolean  @default(false)
  pulseEnabled          Boolean  @default(false)
  readAloudEnabled      Boolean  @default(false)
  staffWellbeingEnabled Boolean  @default(false)
  dslEmail              String?  // Designated Safeguarding Lead — receives flagged content alerts
  authMode              String   @default("both") // "password" | "sso" | "both"
  inspectorate          String   @default("generic") // "ofsted" | "khda" | "adek" | "estyn" | "generic"
  frameworkId      String?
  framework        Framework? @relation(fields: [frameworkId], references: [id])
  admins               Admin[]
  teachers             Teacher[]
  yearGroups           YearGroup[]
  classGroups          ClassGroup[]
  students             Student[]
  surveys              Survey[]
  frameworkAssignments FrameworkAssignment[]
  smartGroups          SmartGroup[]
  checkInRequests      CheckInRequest[]
  bankQuestions        SurveyBankQuestion[]
  terms                Term[]
  assessmentWindows    AssessmentWindow[]
  pulseSchedules       PulseSchedule[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============ FRAMEWORKS ============

model Framework {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  description         String?
  config              String   @default("{}")
  isDefault           Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdBy           String?
  assessmentFrequency String   @default("termly")
  activeTerms         String   @default("[\"term1\",\"term2\",\"term3\"]")
  domains             FrameworkDomain[]
  questions           FrameworkQuestion[]
  scoringModels       FrameworkScoringModel[]
  interventions       Intervention[]
  pulseQuestions      PulseQuestion[]
  schools             School[]
  assignments         FrameworkAssignment[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model FrameworkAssignment {
  id          String    @id @default(cuid())
  frameworkId String
  framework   Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assignedAt  DateTime  @default(now())

  @@unique([frameworkId, schoolId])
}

model FrameworkDomain {
  id          String    @id @default(cuid())
  frameworkId String
  framework   Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  key         String
  label       String
  description String?
  color       String    @default("blue")
  sortOrder   Int       @default(0)
  messages    FrameworkDomainMessage[]

  @@unique([frameworkId, key])
}

model FrameworkDomainMessage {
  id                String          @id @default(cuid())
  frameworkDomainId String
  frameworkDomain   FrameworkDomain @relation(fields: [frameworkDomainId], references: [id], onDelete: Cascade)
  messageType       String          // "strength", "strength_junior", "next_step", "next_step_junior"
  content           String
  sortOrder         Int             @default(0)
}

model FrameworkScoringModel {
  id                 String    @id @default(cuid())
  frameworkId        String
  framework          Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  key                String    // "standard", "junior"
  name               String    // "Standard (8-11)"
  thresholds         String    // JSON: [{level, min}] for per-domain
  overallThresholds  String    // JSON: [{level, min}] for overall
  maxDomainScore     Float
  maxTotalScore      Float

  @@unique([frameworkId, key])
}

model FrameworkQuestion {
  id             String    @id @default(cuid())
  frameworkId    String
  framework      Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  domainKey      String
  tier           String    @default("standard")
  orderIndex     Int
  prompt         String
  type           String    @default("core")
  questionFormat String    @default("self-report")
  answerOptions  String
  scoreMap       String
  weight         Float     @default(1.0)
  isValidation   Boolean   @default(false)
  isTrap         Boolean   @default(false)
  validationPair Int?
  audioUrl       String?
  symbolImageUrl String?

  @@unique([frameworkId, tier, orderIndex])
}

// ============ SCHOOL AUTH ============

model Admin {
  id           String   @id @default(cuid())
  email        String
  passwordHash String
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([email, schoolId])
}

model Teacher {
  id                 String              @id @default(cuid())
  firstName          String
  lastName           String
  email              String              @unique
  passwordHash       String
  schoolId           String
  school             School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes            ClassGroup[]
  teacherAssessments TeacherAssessment[]
  staffAssessments   StaffAssessment[]
  staffPulseChecks   StaffPulseCheck[]
  checkInRequests    CheckInRequest[]
  smartGroupsCreated SmartGroup[]        @relation("SmartGroupCreator")
  smartGroupAccess   SmartGroupTeacher[]
  createdAt          DateTime            @default(now())
  lastLoginAt        DateTime?
  tags               String              @default("[]") // JSON array of role tags
}

// ============ SCHOOL STRUCTURE ============

model YearGroup {
  id        String       @id @default(cuid())
  name      String
  sortOrder Int          @default(0)
  tier      String       @default("standard")
  schoolId  String
  school    School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes   ClassGroup[]
  students  Student[]
  createdAt DateTime     @default(now())

  @@unique([schoolId, name])
}

model ClassGroup {
  id          String    @id @default(cuid())
  name        String
  yearGroupId String
  yearGroup   YearGroup @relation(fields: [yearGroupId], references: [id], onDelete: Cascade)
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students    Student[]
  teachers    Teacher[]
  createdAt   DateTime  @default(now())

  @@unique([yearGroupId, name])
}

// ============ STUDENTS ============

model Student {
  id                 String              @id @default(cuid())
  loginCode          String              @unique
  firstName          String
  lastName           String
  displayName        String?
  yearGroup          String
  className          String?
  yearGroupId        String?
  yearGroupRef       YearGroup?          @relation(fields: [yearGroupId], references: [id])
  classGroupId       String?
  classGroupRef      ClassGroup?         @relation(fields: [classGroupId], references: [id])
  tier               String              @default("standard")
  sen                Boolean             @default(false)
  magt               Boolean             @default(false)
  eal                Boolean             @default(false)
  schoolUuid         String?
  schoolId           String
  school             School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt          DateTime            @default(now())
  assessments        Assessment[]
  teacherAssessments TeacherAssessment[]
  pulseChecks        PulseCheck[]
  surveyResponses    SurveyResponse[]
  checkInRequests    CheckInRequest[]
  smartGroupMemberships SmartGroupStudent[]
}

// ============ STUDENT QUESTIONS & ASSESSMENTS ============

model Question {
  id             String  @id @default(cuid())
  tier           String  @default("standard")
  orderIndex     Int
  prompt         String
  domain         String
  type           String
  questionFormat String
  answerOptions  String
  scoreMap       String
  weight         Float   @default(1.0)
  isValidation   Boolean @default(false)
  isTrap         Boolean @default(false)
  audioUrl       String?
  symbolImageUrl String?
  validationPair Int?

  @@unique([tier, orderIndex])
}

model Assessment {
  id                    String    @id @default(cuid())
  studentId             String
  student               Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tier                  String    @default("standard")
  term                  String    @default("term1")
  academicYear          String    @default("2025-2026")
  status                String    @default("in_progress")
  isReduced             Boolean   @default(false)
  answers               String    @default("{}")
  totalScore            Float?
  overallLevel          String?
  reliabilityScore      String?
  rawResponseJson       String?
  domainScoresJson      String?   // JSON: { "domain": score, ... }
  domainLevelsJson      String?   // JSON: { "domain": "Secure", ... }
  frameworkId           String?
  lastQuestionNum       Int       @default(0)
  startedAt             DateTime  @default(now())
  completedAt           DateTime?
  domainScoreRecords    AssessmentDomainScore[]

  @@unique([studentId, term, academicYear])
  @@index([studentId, status])
  @@index([status, academicYear])
}

model AssessmentDomainScore {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  domainKey    String
  score        Float
  level        String

  @@unique([assessmentId, domainKey])
}

// ============ TEACHER QUESTIONS & ASSESSMENTS ============

model TeacherQuestion {
  id            String @id @default(cuid())
  orderIndex    Int    @unique
  prompt        String
  domain        String
  answerOptions String
  scoreMap      String
  weight        Float  @default(1.0)
}

model TeacherAssessment {
  id                    String    @id @default(cuid())
  teacherId             String
  teacher               Teacher   @relation(fields: [teacherId], references: [id])
  studentId             String
  student               Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term                  String
  academicYear          String    @default("2025-2026")
  status                String    @default("in_progress")
  answers               String    @default("{}")
  domainScoresJson      String?
  domainLevelsJson      String?
  frameworkId                  String?
  completedAt                  DateTime?
  createdAt                    DateTime  @default(now())
  domainScoreRecords           TeacherAssessmentDomainScore[]

  @@unique([teacherId, studentId, term, academicYear])
  @@index([teacherId, term, academicYear])
  @@index([studentId, status])
}

model TeacherAssessmentDomainScore {
  id                    String            @id @default(cuid())
  teacherAssessmentId   String
  teacherAssessment     TeacherAssessment @relation(fields: [teacherAssessmentId], references: [id], onDelete: Cascade)
  domainKey             String
  score                 Float
  level                 String

  @@unique([teacherAssessmentId, domainKey])
}

// ============ WEEKLY PULSE ============

model PulseQuestion {
  id          String     @id @default(cuid())
  domain      String
  prompt      String
  tier        String     @default("standard")
  emoji       String?
  audioUrl    String?
  orderIndex  Int
  frameworkId String?
  framework   Framework? @relation(fields: [frameworkId], references: [id], onDelete: Cascade)

  @@unique([frameworkId, tier, domain])
}

model PulseCheck {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  weekOf      DateTime
  answers     String    @default("{}") // JSON: { "KnowMe": 3, ... }
  freeText    String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([studentId, weekOf])
  @@index([weekOf, completedAt])
  @@index([studentId, completedAt])
}

// ============ BESPOKE SURVEYS ============

model Survey {
  id           String           @id @default(cuid())
  schoolId     String
  school       School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  status       String           @default("draft") // draft | active | closed
  openAt       DateTime?
  closeAt      DateTime?
  targetType   String           @default("school") // school | year_group | class
  targetIds    String           @default("[]") // JSON array of IDs
  anonymous    Boolean          @default(false)
  allowRetake  Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  questions    SurveyQuestion[]
  responses    SurveyResponse[]

  @@index([schoolId, status])
  @@index([schoolId, openAt, closeAt])
}

model SurveyQuestion {
  id           String           @id @default(cuid())
  surveyId     String
  survey       Survey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  orderIndex   Int
  prompt       String
  questionType String           // likert_5 | multiple_choice | yes_no | rating_10 | free_text
  options      String?          // JSON array for multiple_choice
  required     Boolean          @default(true)

  @@unique([surveyId, orderIndex])
}

// Curated bank of pre-written questions admins pick from when building a
// survey, instead of writing each from scratch. Platform-seeded entries have
// schoolId=null and isDefault=true; schools can add their own with schoolId
// set so an inclusion lead can build up a reusable set.
model SurveyBankQuestion {
  id             String   @id @default(cuid())
  prompt         String
  description    String?
  questionType   String   // matches SurveyQuestion.questionType
  defaultOptions String?  // JSON for multiple_choice defaults
  category       String   // e.g. "Emotional Wellbeing"
  subcategory    String?  // optional finer-grained label
  domainKey      String?  // optional framework-domain hint (e.g. "ManageMe")
  ageTags        String   @default("[\"junior\",\"standard\"]") // JSON array
  source         String?  // attribution: "PERMA", "EPOCH", "MeQ", etc.
  isDefault      Boolean  @default(true)
  schoolId       String?
  school         School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category])
  @@index([schoolId, isDefault])
}

model SurveyResponse {
  id          String   @id @default(cuid())
  surveyId    String
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  studentId   String?  // null if anonymous
  student     Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  answers     String   @default("{}") // JSON: { questionId: answer }
  flagged     Boolean  @default(false) // flagged by free text moderation
  flagReason  String?  // keyword(s) matched
  completedAt DateTime @default(now())
}

// ============ STAFF WELLBEING ============
// Staff wellbeing is system-wide, not tied to frameworks.
// Super admin manages the staff domains, questions, and scoring;
// schools just toggle it on.

model StaffDomain {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  color       String   @default("blue")
  sortOrder   Int      @default(0)
  questions   StaffQuestion[]
  pulseQuestions StaffPulseQuestion[]
}

model StaffQuestion {
  id             String      @id @default(cuid())
  domainId       String
  domain         StaffDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  orderIndex     Int         @unique
  prompt         String
  type           String      @default("core")
  questionFormat String      @default("self-report")
  answerOptions  String
  scoreMap       String
  weight         Float       @default(1.0)
  isValidation   Boolean     @default(false)
}

model StaffPulseQuestion {
  id         String      @id @default(cuid())
  domainId   String      @unique
  domain     StaffDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  prompt     String
  emoji      String?
  orderIndex Int         @default(0)
}

model StaffScoringConfig {
  id                String @id @default(cuid())
  key               String @unique @default("default")
  thresholds        String // JSON [{level, min}]
  overallThresholds String // JSON [{level, min}]
  maxDomainScore    Float
  maxTotalScore     Float
}

model StaffAssessment {
  id                String    @id @default(cuid())
  teacherId         String
  teacher           Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  term              String
  academicYear      String
  status            String    @default("in_progress")
  answers           String    @default("{}")
  totalScore        Float?
  overallLevel      String?
  domainScoresJson  String?
  domainLevelsJson  String?
  startedAt         DateTime  @default(now())
  completedAt       DateTime?

  @@unique([teacherId, term, academicYear])
}

model StaffIntervention {
  id          String   @id @default(cuid())
  domainKey   String   // matches StaffDomain.key
  level       String   // "Emerging" | "Developing" | "Secure" | "Advanced"
  title       String
  description String
  sortOrder   Int      @default(0)
  isDefault   Boolean  @default(true)
  schoolId    String?  // null = system default, set = school-custom
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StaffWellbeingNotification {
  id           String   @id @default(cuid())
  teacherId    String
  term         String
  academicYear String
  sentAt       DateTime @default(now())

  @@unique([teacherId, term, academicYear])
  @@index([term, academicYear])
}

model StaffWellbeingNudge {
  id             String   @id @default(cuid())
  schoolId       String
  term           String
  academicYear   String
  sentAt         DateTime @default(now())
  recipientCount Int

  @@index([schoolId, term, academicYear, sentAt])
}

model SchoolSafeguardingKeyword {
  id             String   @id @default(cuid())
  schoolId       String
  keyword        String
  addedAt        DateTime @default(now())
  addedByAdminId String?

  @@unique([schoolId, keyword])
  @@index([schoolId])
}

model AuditLog {
  id         String   @id @default(cuid())
  schoolId   String?
  actorType  String   // "admin" | "teacher" | "super" | "system"
  actorId    String?
  actorLabel String?  // denormalised email or name for display
  action     String   // e.g. "student.delete", "survey.delete", "alert.resolve"
  entityType String?
  entityId   String?
  meta       String?  // optional JSON string with extra context
  createdAt  DateTime @default(now())

  @@index([schoolId, createdAt])
  @@index([action, createdAt])
}

model Notification {
  id         String    @id @default(cuid())
  userType   String    // "admin" | "teacher" | "super"
  userId     String
  schoolId   String?
  category   String    // "safeguarding" | "survey" | "assessment" | "system"
  title      String
  body       String?
  href       String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userType, userId, readAt])
  @@index([userType, userId, createdAt])
}

model StaffWellbeingInsight {
  id            String   @id @default(cuid())
  schoolId      String
  term          String
  academicYear  String
  narrativeJson String   // JSON: { summary, strengths[], developmentAreas[], nextSteps[] }
  modelUsed     String?
  cohortSize    Int
  generatedAt   DateTime @default(now())

  @@unique([schoolId, term, academicYear])
  @@index([schoolId])
}

// Cross-class cohorts — e.g. inclusion teacher's nurture group, social skills group,
// MAGT cohort monitoring. Can contain students from any class/year. Visible to the
// creator (teacher or admin) + any teachers explicitly shared with + all school admins.
model SmartGroup {
  id              String              @id @default(cuid())
  schoolId        String
  school          School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  purpose         String?             // free-form tag, e.g. "Nurture", "Social skills", "MAGT"
  createdByType   String              // "admin" | "teacher"
  createdByTeacher Teacher?           @relation("SmartGroupCreator", fields: [createdByTeacherId], references: [id], onDelete: SetNull)
  createdByTeacherId String?
  createdByAdminId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  members         SmartGroupStudent[]
  teacherAccess   SmartGroupTeacher[]

  @@index([schoolId])
}

model SmartGroupStudent {
  smartGroupId String
  smartGroup   SmartGroup @relation(fields: [smartGroupId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  addedAt      DateTime   @default(now())

  @@id([smartGroupId, studentId])
  @@index([studentId])
}

model SmartGroupTeacher {
  smartGroupId String
  smartGroup   SmartGroup @relation(fields: [smartGroupId], references: [id], onDelete: Cascade)
  teacherId    String
  teacher      Teacher    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  addedAt      DateTime   @default(now())

  @@id([smartGroupId, teacherId])
  @@index([teacherId])
}

// ============ SCHEDULING / CALENDAR ============
//
// Replaces the older single-school-currentTerm + framework activeTerms +
// pulseEnabled boolean model. Calendar is the source of truth: terms have
// real start/end dates, half-term breaks are explicit exclusion windows,
// assessment windows define when the framework full-survey runs (1-3 per
// year — schools choose which terms), and pulse schedules generate
// occurrence dates that automatically skip half-terms and respect the
// "no pulse on assessment day, min 1 week post-assessment" rules.

model Term {
  id           String          @id @default(cuid())
  schoolId     String
  school       School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear String          // e.g. "2025-2026"
  key          String          // "term1" | "term2" | "term3" — stable identifier
  name         String          // "Autumn", "Spring", "Summer" — display label
  startDate    DateTime        @db.Date
  endDate      DateTime        @db.Date
  sortOrder    Int             @default(0)
  halfTerms    HalfTermBreak[]

  @@unique([schoolId, academicYear, key])
  @@index([schoolId, academicYear, startDate])
}

model HalfTermBreak {
  id        String   @id @default(cuid())
  termId    String
  term      Term     @relation(fields: [termId], references: [id], onDelete: Cascade)
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  label     String?  // e.g. "October half-term"

  @@index([termId])
}

model AssessmentWindow {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear String
  termKey      String   // matches Term.key
  openAt       DateTime
  closeAt      DateTime

  @@unique([schoolId, academicYear, termKey])
  @@index([schoolId, openAt, closeAt])
}

model PulseSchedule {
  id           String           @id @default(cuid())
  schoolId     String
  school       School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear String
  cadence      String           // "weekly" | "biweekly" | "monthly" | "custom"
  dayOfWeek    Int              @default(1) // 1=Mon..5=Fri (0/6 allowed but unusual)
  startDate    DateTime         @db.Date
  endDate      DateTime?        @db.Date
  active       Boolean          @default(true)
  occurrences  PulseOccurrence[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([schoolId, academicYear])
  @@index([schoolId, active])
}

model PulseOccurrence {
  id          String   @id @default(cuid())
  scheduleId  String
  schedule    PulseSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  status      String   @default("scheduled") // "scheduled" | "skipped" | "ad_hoc"
  skipReason  String?

  @@unique([scheduleId, date])
  @@index([date, status])
}

model CheckInRequest {
  id              String    @id @default(cuid())
  schoolId        String
  school          School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  targetTeacherId String?
  targetTeacher   Teacher?  @relation(fields: [targetTeacherId], references: [id], onDelete: SetNull)
  freeText        String?
  status          String    @default("open") // "open" | "resolved"
  notes           String?
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?
  resolvedByType  String?   // "admin" | "teacher"
  resolvedById    String?

  @@index([schoolId, status, createdAt])
  @@index([targetTeacherId, status])
  @@index([studentId, createdAt])
}

model SafeguardingAlert {
  id               String   @id @default(cuid())
  schoolId         String
  type             String   // "pulse" | "survey"
  studentId        String?  // null for anonymous surveys
  pulseCheckId     String?
  surveyResponseId String?
  flagReason       String   // matched keywords or "Low pulse scores"
  flaggedText      String?  // free-text excerpt when relevant
  status           String   @default("open") // "open" | "resolved" | "dismissed"
  notes            String?
  resolvedAt       DateTime?
  resolvedByAdminId String?
  createdAt        DateTime @default(now())

  @@index([schoolId, status, createdAt])
}

model StaffPulseCheck {
  id          String    @id @default(cuid())
  teacherId   String
  teacher     Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  weekOf      DateTime
  answers     String    @default("{}")
  freeText    String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([teacherId, weekOf])
}

// ============ SECURITY ============

model FailedLoginAttempt {
  id          String   @id @default(cuid())
  email       String
  userType    String   // "admin" | "teacher" | "super"
  attemptedAt DateTime @default(now())

  @@index([email, userType, attemptedAt])
}

// ============ PASSWORD RESET ============

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  userType  String    // "admin" | "teacher" | "super"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// ============ INTERVENTIONS ============

model InterventionLog {
  id             String   @id @default(cuid())
  studentId      String
  teacherId      String?  // null if logged by an admin
  adminId        String?
  schoolId       String
  // We don't FK to Intervention or StaffIntervention because either could be
  // referenced; store the source ("intervention" | "staff_intervention") and id.
  source         String   @default("intervention")
  interventionId String?
  domainKey      String
  level          String
  title          String
  notes          String?
  appliedAt      DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([studentId, appliedAt])
  @@index([schoolId, appliedAt])
}

model Intervention {
  id          String     @id @default(cuid())
  domain      String     // domain key (matches FrameworkDomain.key)
  level       String
  tier        String     @default("standard")
  audience    String     // "student" | "teacher"
  title       String
  description String
  sortOrder   Int        @default(0)
  isDefault   Boolean    @default(true)
  schoolId    String?    // null = system/framework default, set = school custom
  frameworkId String?    // null = legacy MeQ Standard, set = framework-specific
  framework   Framework? @relation(fields: [frameworkId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
