generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ SUPER ADMIN (platform owner) ============

model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

// ============ SCHOOL ============

model School {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique // URL-friendly identifier
  currentTerm  String   @default("term1")
  academicYear String   @default("2025-2026")
  isActive         Boolean  @default(true)
  reducedQuestions Boolean  @default(false)
  pulseEnabled     Boolean  @default(false)
  readAloudEnabled Boolean  @default(false)
  frameworkId      String?
  framework        Framework? @relation(fields: [frameworkId], references: [id])
  admins       Admin[]
  teachers     Teacher[]
  yearGroups   YearGroup[]
  classGroups  ClassGroup[]
  students     Student[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============ FRAMEWORKS ============

model Framework {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  config        String   @default("{}") // Legacy JSON config (being replaced by scoring models)
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdBy     String?
  domains       FrameworkDomain[]
  questions     FrameworkQuestion[]
  scoringModels FrameworkScoringModel[]
  schools       School[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FrameworkDomain {
  id          String    @id @default(cuid())
  frameworkId String
  framework   Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  key         String
  label       String
  description String?
  color       String    @default("blue")
  sortOrder   Int       @default(0)
  messages    FrameworkDomainMessage[]

  @@unique([frameworkId, key])
}

model FrameworkDomainMessage {
  id                String          @id @default(cuid())
  frameworkDomainId String
  frameworkDomain   FrameworkDomain @relation(fields: [frameworkDomainId], references: [id], onDelete: Cascade)
  messageType       String          // "strength", "strength_junior", "next_step", "next_step_junior"
  content           String
  sortOrder         Int             @default(0)
}

model FrameworkScoringModel {
  id                 String    @id @default(cuid())
  frameworkId        String
  framework          Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  key                String    // "standard", "junior"
  name               String    // "Standard (8-11)"
  thresholds         String    // JSON: [{level, min}] for per-domain
  overallThresholds  String    // JSON: [{level, min}] for overall
  maxDomainScore     Float
  maxTotalScore      Float

  @@unique([frameworkId, key])
}

model FrameworkQuestion {
  id             String    @id @default(cuid())
  frameworkId    String
  framework      Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  domainKey      String
  tier           String    @default("standard")
  orderIndex     Int
  prompt         String
  type           String    @default("core")
  questionFormat String    @default("self-report")
  answerOptions  String
  scoreMap       String
  weight         Float     @default(1.0)
  isValidation   Boolean   @default(false)
  isTrap         Boolean   @default(false)
  validationPair Int?
  audioUrl       String?
  symbolImageUrl String?

  @@unique([frameworkId, tier, orderIndex])
}

// ============ SCHOOL AUTH ============

model Admin {
  id           String   @id @default(cuid())
  email        String
  passwordHash String
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([email, schoolId])
}

model Teacher {
  id                 String              @id @default(cuid())
  firstName          String
  lastName           String
  email              String              @unique
  passwordHash       String
  schoolId           String
  school             School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes            ClassGroup[]
  teacherAssessments TeacherAssessment[]
  createdAt          DateTime            @default(now())
}

// ============ SCHOOL STRUCTURE ============

model YearGroup {
  id        String       @id @default(cuid())
  name      String
  sortOrder Int          @default(0)
  tier      String       @default("standard")
  schoolId  String
  school    School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes   ClassGroup[]
  students  Student[]
  createdAt DateTime     @default(now())

  @@unique([schoolId, name])
}

model ClassGroup {
  id          String    @id @default(cuid())
  name        String
  yearGroupId String
  yearGroup   YearGroup @relation(fields: [yearGroupId], references: [id], onDelete: Cascade)
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students    Student[]
  teachers    Teacher[]
  createdAt   DateTime  @default(now())

  @@unique([yearGroupId, name])
}

// ============ STUDENTS ============

model Student {
  id                 String              @id @default(cuid())
  loginCode          String              @unique
  firstName          String
  lastName           String
  displayName        String?
  yearGroup          String
  className          String?
  yearGroupId        String?
  yearGroupRef       YearGroup?          @relation(fields: [yearGroupId], references: [id])
  classGroupId       String?
  classGroupRef      ClassGroup?         @relation(fields: [classGroupId], references: [id])
  tier               String              @default("standard")
  sen                Boolean             @default(false)
  schoolUuid         String?
  schoolId           String
  school             School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt          DateTime            @default(now())
  assessments        Assessment[]
  teacherAssessments TeacherAssessment[]
  pulseChecks        PulseCheck[]
}

// ============ STUDENT QUESTIONS & ASSESSMENTS ============

model Question {
  id             String  @id @default(cuid())
  tier           String  @default("standard")
  orderIndex     Int
  prompt         String
  domain         String
  type           String
  questionFormat String
  answerOptions  String
  scoreMap       String
  weight         Float   @default(1.0)
  isValidation   Boolean @default(false)
  isTrap         Boolean @default(false)
  audioUrl       String?
  symbolImageUrl String?
  validationPair Int?

  @@unique([tier, orderIndex])
}

model Assessment {
  id                    String    @id @default(cuid())
  studentId             String
  student               Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tier                  String    @default("standard")
  term                  String    @default("term1")
  academicYear          String    @default("2025-2026")
  status                String    @default("in_progress")
  isReduced             Boolean   @default(false)
  answers               String    @default("{}")
  totalScore            Float?
  overallLevel          String?
  knowMeScore           Float?
  manageMeScore         Float?
  understandOthersScore Float?
  workWithOthersScore   Float?
  chooseWellScore       Float?
  knowMeLevel           String?
  manageMeLevel         String?
  understandOthersLevel String?
  workWithOthersLevel   String?
  chooseWellLevel       String?
  reliabilityScore      String?
  rawResponseJson       String?
  domainScoresJson      String?   // JSON: { "KnowMe": 15.5, ... } — for framework-based scoring
  domainLevelsJson      String?   // JSON: { "KnowMe": "Secure", ... }
  frameworkId           String?
  lastQuestionNum       Int       @default(0)
  startedAt             DateTime  @default(now())
  completedAt           DateTime?
  domainScoreRecords    AssessmentDomainScore[]

  @@unique([studentId, term, academicYear])
}

model AssessmentDomainScore {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  domainKey    String
  score        Float
  level        String

  @@unique([assessmentId, domainKey])
}

// ============ TEACHER QUESTIONS & ASSESSMENTS ============

model TeacherQuestion {
  id            String @id @default(cuid())
  orderIndex    Int    @unique
  prompt        String
  domain        String
  answerOptions String
  scoreMap      String
  weight        Float  @default(1.0)
}

model TeacherAssessment {
  id                    String    @id @default(cuid())
  teacherId             String
  teacher               Teacher   @relation(fields: [teacherId], references: [id])
  studentId             String
  student               Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term                  String
  academicYear          String    @default("2025-2026")
  status                String    @default("in_progress")
  answers               String    @default("{}")
  knowMeScore           Float?
  manageMeScore         Float?
  understandOthersScore Float?
  workWithOthersScore   Float?
  chooseWellScore       Float?
  knowMeLevel           String?
  manageMeLevel         String?
  understandOthersLevel String?
  workWithOthersLevel   String?
  chooseWellLevel       String?
  domainScoresJson      String?
  domainLevelsJson      String?
  frameworkId                  String?
  completedAt                  DateTime?
  createdAt                    DateTime  @default(now())
  domainScoreRecords           TeacherAssessmentDomainScore[]

  @@unique([teacherId, studentId, term, academicYear])
}

model TeacherAssessmentDomainScore {
  id                    String            @id @default(cuid())
  teacherAssessmentId   String
  teacherAssessment     TeacherAssessment @relation(fields: [teacherAssessmentId], references: [id], onDelete: Cascade)
  domainKey             String
  score                 Float
  level                 String

  @@unique([teacherAssessmentId, domainKey])
}

// ============ WEEKLY PULSE ============

model PulseQuestion {
  id         String  @id @default(cuid())
  domain     String
  prompt     String
  tier       String  @default("standard")
  emoji      String?
  orderIndex Int

  @@unique([tier, domain])
}

model PulseCheck {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  weekOf      DateTime
  answers     String    @default("{}") // JSON: { "KnowMe": 3, ... }
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([studentId, weekOf])
}

// ============ PASSWORD RESET ============

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  userType  String    // "admin" | "teacher" | "super"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// ============ INTERVENTIONS ============

model Intervention {
  id          String   @id @default(cuid())
  domain      String
  level       String
  tier        String   @default("standard")
  audience    String
  title       String
  description String
  sortOrder   Int      @default(0)
  isDefault   Boolean  @default(true)
  schoolId    String?  // null = system default, set = school custom
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
